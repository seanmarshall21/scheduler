# Supabase (NEW project, separate from CRFTD)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Functions only — never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (reusing CRFTD's Google Cloud project — add this app's redirect
# URIs to that OAuth client). Used by the google-* Netlify functions.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Web Push (optional, for task/reminder notifications) — generate with web-push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=
