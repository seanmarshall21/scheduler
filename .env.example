# Supabase (NEW project, separate from CRFTD)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Functions only — never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar (multi-account). The browser builds the OAuth URL, so the
# client id must ALSO be exposed with the VITE_ prefix. The redirect URI for this
# flow is <your-site>/settings — add that and http://localhost:5173/settings to
# the OAuth client's Authorized redirect URIs. Scope: calendar + email.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Work schedule bridge (CRFTD → ClickUp). Reads your CRFTD schedule_blocks and
# resolves titles/colors from ClickUp. Functions only — never exposed to browser.
#   CRFTD_SUPABASE_*  : the CRFTD project's URL + service-role key (read blocks)
#   CLICKUP_API_TOKEN : ClickUp personal token (task titles/colors)
#   CLICKUP_USER_MAP  : optional JSON {"email":"clickup_user_id"} (defaults sean)
CRFTD_SUPABASE_URL=
CRFTD_SUPABASE_SERVICE_ROLE_KEY=
CLICKUP_API_TOKEN=
CLICKUP_USER_MAP=

# Web Push (optional, for task/reminder notifications) — generate with web-push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY=
